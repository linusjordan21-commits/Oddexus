[Unit]
Description=Universal odds self-healer (kör om stale källor automatiskt)
After=odds-health.service

[Service]
Type=oneshot
User=root
Environment=INSTALL_DIR=__INSTALL_DIR__
WorkingDirectory=__INSTALL_DIR__
ExecStart=/usr/bin/env bash __INSTALL_DIR__/vps/self-heal.sh
StandardOutput=journal
StandardError=journal
